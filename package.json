{
  "name": "ezascii-figma-plugins",
  "private": true,
  "version": "0.0.0",
  "description": "Figma plugins for ASCII text art and image-to-ASCII conversion. Built by the team behind ezascii.com.",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint \"packages/**/src/**/*.ts\"",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "packageManager": "pnpm@8.15.0"
}
